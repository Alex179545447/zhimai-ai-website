                        <span style="padding: 8px 16px; background: #e6fcf5; color: #00d4aa; border-radius: var(--radius-md); font-size: 13px;">✓ HTTPS加密传输</span>
                        <span style="padding: 8px 16px; background: #e6fcf5; color: #00d4aa; border-radius: var(--radius-md); font-size: 13px;">✓ MD5加密存储</span>
                        <span style="padding: 8px 16px; background: #e6fcf5; color: #00d4aa; border-radius: var(--radius-md); font-size: 13px;">✓ 权限控制</span>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Email Modal -->
    <div class="modal-overlay" id="emailModal">
        <div class="modal">
            <h2>邮箱收取简历</h2>
            <p style="font-size: 14px; color: var(--text-gray); margin-bottom: 24px;">
                填写接收各渠道简历的邮箱，新简历会自动同步到系统中
            </p>
            <div class="form-group">
                <label>邮箱地址</label>
                <input type="email" placeholder="请输入邮箱地址">
            </div>
            <div class="form-group">
                <label>邮箱密码</label>
                <input type="password" placeholder="请输入邮箱密码或授权码">
            </div>
            <div style="display: flex; gap: 12px; margin-top: 24px;">
                <button class="btn btn-primary" style="flex: 1;" onclick="closeEmailModal()">绑定</button>
                <button class="btn btn-secondary" style="flex: 1;" onclick="closeEmailModal()">取消</button>
            </div>
        </div>
    </div>

    <!-- Job Modal -->
    <div class="modal-overlay" id="jobModal">
        <div class="modal">
            <h2>发布新职位</h2>
            <div class="form-group">
                <label>职位名称</label>
                <input type="text" placeholder="请输入职位名称">
            </div>
            <div class="form-group">
                <label>职位描述</label>
                <textarea style="width: 100%; padding: 12px 16px; border: 1px solid var(--border-color); border-radius: var(--radius-md); font-size: 15px; min-height: 100px; resize: vertical;" placeholder="请输入职位描述或JD"></textarea>
            </div>
            <div class="form-group">
                <label>薪资范围</label>
                <input type="text" placeholder="如：15K-30K">
            </div>
            <div class="form-group">
                <label>工作地点</label>
                <input type="text" placeholder="请输入工作地点">
            </div>
            <div style="display: flex; gap: 12px; margin-top: 24px;">
                <button class="btn btn-primary" style="flex: 1;" onclick="closeJobModal()">发布</button>
                <button class="btn btn-secondary" style="flex: 1;" onclick="closeJobModal()">取消</button>
            </div>
        </div>
    </div>

    <!-- Reach Modal -->
    <div class="modal-overlay" id="reachModal">
        <div class="modal">
            <h2 id="reachModalTitle">触达候选人</h2>
            <div class="form-group">
                <label>选择候选人</label>
                <select id="reachTarget">
                    <option>张明 - 高级算法工程师</option>
                    <option>李华 - 产品经理</option>
                    <option>王芳 - 数据分析师</option>
                    <option>批量选择</option>
                </select>
            </div>
            <div class="form-group">
                <label>触达方式</label>
                <select id="reachMethod">
                    <option>微信消息</option>
                    <option>短信</option>
                    <option>邮件</option>
                </select>
            </div>
            <div class="form-group">
                <label>消息内容</label>
                <textarea style="width: 100%; padding: 12px 16px; border: 1px solid var(--border-color); border-radius: var(--radius-md); font-size: 15px; min-height: 120px; resize: vertical;" placeholder="请输入消息内容..."></textarea>
            </div>
            <div style="display: flex; gap: 12px; margin-top: 24px;">
                <button class="btn btn-primary" style="flex: 1;" onclick="sendReach()">发送</button>
                <button class="btn btn-secondary" style="flex: 1;" onclick="closeReachModal()">取消</button>
            </div>
        </div>
    </div>

    <script>
        // Demo login function
        function enterDemo() {
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('appContainer').classList.add('active');
        }

        // Tab switching for login/register
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', function() {
                const tabName = this.dataset.tab;
                
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                
                if (tabName === 'login') {
                    document.getElementById('loginForm').style.display = 'block';
                    document.getElementById('registerForm').style.display = 'none';
                } else {
                    document.getElementById('loginForm').style.display = 'none';
                    document.getElementById('registerForm').style.display = 'block';
                }
            });
        });

        // Login form submission - 直接登录进入系统
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            enterDemo();
        });

        // Register form submission - 直接登录进入系统
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            enterDemo();
        });

        // Navigation
        function navigateTo(pageName) {
            // Update nav links
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
                if (link.dataset.page === pageName) {
                    link.classList.add('active');
                }
            });

            // Update page sections
            document.querySelectorAll('.page-section').forEach(section => {
                section.classList.remove('active');
            });
            document.getElementById('page-' + pageName).classList.add('active');
        }

        // Nav link clicks
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', function() {
                const pageName = this.dataset.page;
                navigateTo(pageName);
            });
        });

        // File upload
        function triggerFileUpload() {
            document.getElementById('fileInput').click();
        }

        document.getElementById('fileInput').addEventListener('change', function(e) {
            const files = e.target.files;
            if (files.length > 0) {
                alert('已选择 ' + files.length + ' 个文件，正在上传并解析...');
                setTimeout(() => {
                    alert('简历上传成功！AI正在解析中...');
                }, 1000);
            }
        });

        // Email modal
        function openEmailModal() {
            document.getElementById('emailModal').classList.add('active');
        }

        function closeEmailModal() {
            document.getElementById('emailModal').classList.remove('active');
        }

        // Job modal
        function openJobModal() {
            document.getElementById('jobModal').classList.add('active');
        }

        function closeJobModal() {
            document.getElementById('jobModal').classList.remove('active');
        }

        // Reach modal
        function openReachModal(channel) {
            const modal = document.getElementById('reachModal');
            const title = document.getElementById('reachModalTitle');
            const method = document.getElementById('reachMethod');
            
            const channelNames = {
                'wechat': '微信触达',
                'sms': '短信关怀',
                'email': '邮件推送',
                'schedule': '定时提醒'
            };
            
            title.textContent = channelNames[channel] || '触达候选人';
            method.value = channel === 'wechat' ? '微信消息' : 
                          channel === 'sms' ? '短信' : 
                          channel === 'email' ? '邮件' : '自动提醒';
            
            modal.classList.add('active');
        }

        function closeReachModal() {
            document.getElementById('reachModal').classList.remove('active');
        }

        function sendReach() {
            alert('发送成功！候选人将收到您的关怀消息');
            closeReachModal();
        }

        // Batch reach
        function openBatchReach() {
            alert('批量触达功能：选择多个候选人，一键发送关怀消息');
        }

        // Talent activation
        function showTalentActivation() {
            alert('待激活人才名单：\n\n1. 张明 - 算法工程师 - 清华大学 - 匹配度98%\n2. 李华 - 产品经理 - 复旦大学 - 匹配度95%\n3. 王芳 - 数据分析师 - 浙江大学 - 匹配度92%');
        }

        // Matching method selection
        document.querySelectorAll('.method-card').forEach(card => {
            card.addEventListener('click', function() {
                document.querySelectorAll('.method-card').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                
                const method = this.dataset.method;
                const methodNames = {
                    'jd': 'JD智能匹配',
                    'skill': '技能标签匹配',
                    'semantic': '语义理解匹配',
                    'vector': '向量相似度',
                    'multi': '多维加权匹配'
                };
                console.log('已选择匹配方式：' + methodNames[method]);
            });
        });

        // Care level selection
        document.querySelectorAll('.care-level').forEach(level => {
            level.addEventListener('click', function() {
                document.querySelectorAll('.care-level').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            });
        });

        // Close modals on overlay click
        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.remove('active');
                }
            });
        });

        // Search functionality
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('.resume-table tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>
