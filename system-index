        /* Loading State */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(3, 3, 7, 0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
